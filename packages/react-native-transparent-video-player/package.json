{
  "name": "react-native-transparent-video-player",
  "version": "0.4.1",
  "description": "Transparent (alpha) video playback for React Native — plays alpha-packed H.264 MP4s on every iOS/Android hardware decoder. Native AVPlayer+Metal view on iOS, native ExoPlayer+OpenGL view on Android, Skia on web. Includes a CLI to pack ProRes 4444 exports.",
  "license": "MIT",
  "author": "LucaL1fe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LucaL1fe/react-native-transparent-video-player.git",
    "directory": "packages/react-native-transparent-video-player"
  },
  "homepage": "https://github.com/LucaL1fe/react-native-transparent-video-player",
  "keywords": [
    "react-native",
    "expo",
    "skia",
    "transparent-video",
    "alpha",
    "animation",
    "mascot",
    "webp-alternative",
    "gif-alternative"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "cli",
    "src",
    "android/build.gradle",
    "android/src",
    "ios",
    "expo-module.config.json",
    "THIRD-PARTY-NOTICES.md"
  ],
  "bin": {
    "pack-transparent-video": "cli/pack-transparent-video.mjs"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@shopify/react-native-skia": ">=1.5.0",
    "expo-asset": "*",
    "expo-modules-core": "*",
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-reanimated": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "expo-asset": {
      "optional": true
    },
    "expo-modules-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@shopify/react-native-skia": "^2.2.12",
    "@types/react": "^19.0.0",
    "expo-modules-core": "~57.0.3",
    "react": "^19.0.0",
    "react-native": "^0.86.0",
    "react-native-reanimated": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
